{
  "name": "copy-as-markdown",
  "version": "1.0.13",
  "description": "Context-aware Copy as Markdown buttons — the fastest way to share web content with LLMs",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsx build/build.ts",
    "clean": "rm -rf dist",
    "rebuild": "pnpm clean && pnpm build",
    "zip:chrome": "cd dist/chrome && zip -r ../copy-as-markdown-chrome.zip .",
    "zip:firefox": "cd dist/firefox && zip -r ../copy-as-markdown-firefox.zip .",
    "package:chrome": "pnpm build && pnpm zip:chrome",
    "package:firefox": "pnpm build && pnpm zip:firefox",
    "package:all": "pnpm build && pnpm zip:chrome && pnpm zip:firefox",
    "test": "pnpm build && node test/test-sites.js",
    "test:site": "pnpm build && node test/test-sites.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bvolpato/copy-as-markdown"
  },
  "keywords": [
    "markdown",
    "copy",
    "clipboard",
    "userscript",
    "browser-extension",
    "chrome-extension",
    "firefox-extension",
    "llm",
    "chatgpt",
    "claude",
    "gemini",
    "web-scraping",
    "content-extraction"
  ],
  "author": "Bruno Volpato <brunocvcunha@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bvolpato/copy-as-markdown/issues"
  },
  "homepage": "https://github.com/bvolpato/copy-as-markdown#readme",
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "esbuild": "^0.25.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
